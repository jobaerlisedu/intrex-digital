rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Certificates collection:
    // Anyone can read (for verification), but only logged-in administrators can create/edit/delete.
    match /learn_certificates/{certificateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Courses collection:
    // Anyone can read (for course directory), but only logged-in administrators can create/edit/delete.
    match /learn_courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Course Registrations collection:
    // Only logged-in administrators can view, edit, or delete registration entries.
    match /learn_registrations/{registrationId} {
      allow read, write: if request.auth != null;
    }
    
    // Online registrations (submitted from public training page)
    match /learn_online_registrations/{regKey} {
      allow create, get: if true;
      allow list, update, delete: if request.auth != null;
    }

    // Online inquiries (submitted from public training/service pages)
    match /learn_online_inquiries/{inquiryKey} {
      allow create, get: if true;
      allow list, update, delete: if request.auth != null;
    }

    // Newsletter subscriptions (submitted from public pages)
    match /learn_newsletter_subscriptions/{email} {
      allow create, get: if true;
      allow list, update, delete: if request.auth != null;
    }
    
    // Payment Records collection:
    // Only logged-in administrators can view or update payments.
    match /learn_payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    // Training Batches collection:
    // Only logged-in administrators can view or update batches.
    match /learn_batches/{batchId} {
      allow read, write: if request.auth != null;
    }

    // Employee Database collection:
    match /learn_tbl_employees/{employeeId} {
      allow read, write: if request.auth != null;
    }

    // Training Audit Logs collection:
    match /learn_tbl_audit_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Public Institutes collection:
    // Only logged-in administrators can view or update public institutes.
    match /learn_public_institutes/{id} {
      allow read, write: if request.auth != null;
    }

    // Job Placements collection:
    // Only logged-in administrators can view or update job placements.
    match /learn_job_placements/{id} {
      allow read, write: if request.auth != null;
    }

    // Expenses collection:
    // Only logged-in administrators can view or update expenses.
    match /learn_expenses/{id} {
      allow read, write: if request.auth != null;
    }

    // Solution Dashboard collections:
    // Only logged-in administrators can view or update these documents.
    match /sol_projects/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_contacts/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_meetings/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_budget/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_tasks/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_requisitions/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_purchase_orders/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_expenses/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_client_payments/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_employees/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_support_tickets/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_domain_hosting_sales/{id} {
      allow read, write: if request.auth != null;
    }
    match /sol_audit_logs/{id} {
      allow read, write: if request.auth != null;
    }

    // Course Final Assessments:
    // Only logged-in administrators can view or update assessments.
    match /learn_course_assessments/{assessmentId} {
      allow read, write: if request.auth != null;
    }
    
    // Marketing Agents collection:
    // Only logged-in administrators can view or update marketing agents.
    match /learn_marketing_agents/{agentId} {
      allow read, write: if request.auth != null;
    }

    // Sales Commissions collection:
    // Only logged-in administrators can view or update commissions.
    match /learn_commissions/{commissionId} {
      allow read, write: if request.auth != null;
    }
    
    // Investment & Finance Dashboard collections:
    // Only logged-in administrators can view or update.
    match /inv_investors/{id} {
      allow read, write: if request.auth != null;
    }
    match /inv_investments/{id} {
      allow read, write: if request.auth != null;
    }
    match /inv_audit_logs/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
