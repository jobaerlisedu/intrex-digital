rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Certificates collection:
    // Anyone can read (for verification), but only logged-in administrators can create/edit/delete.
    match /certificates/{certificateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Course Registrations collection:
    // Only logged-in administrators can view, edit, or delete registration entries.
    match /registrations/{registrationId} {
      allow read, write: if request.auth != null;
    }
    
    // Payment Records collection:
    // Only logged-in administrators can view or update payments.
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    // Solution Dashboard collections:
    // Only logged-in administrators can view or update these documents.
    match /tbl_projects/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_contacts/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_meetings/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_budget/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_tasks/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_requisitions/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_purchase_orders/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_expenses/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_client_payments/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_employees/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_support_tickets/{id} {
      allow read, write: if request.auth != null;
    }
    match /tbl_domain_hosting_sales/{id} {
      allow read, write: if request.auth != null;
    }
    
  }
}
